# Supabase Configuration
# Create a new Supabase project at https://supabase.com
# Copy your project credentials here:
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database (auto-configured from Supabase PostgreSQL connection)
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:password@aws-0-region.pooler.supabase.com:6543/postgres

# Server Configuration
NODE_ENV=development
PORT=5000
HOST=127.0.0.1
# GITHUB_TOKEN=your-github-token
